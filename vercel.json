
{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-reports",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/visit-alerts",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/dashboard-reminders",
      "schedule": "0 21 * * *"
    }
  ]
}
